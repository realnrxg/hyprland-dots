{
  "layer": "top",
  "width": 1920 ,
  "margin-top": 5,

  //modules

  "position": "top",
  "height": 30,
  "margin": 8,
  "spacing": 0,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["cpu", "memory", "disk"],
  "modules-right": ["cava", "traymenu", "network", "backlight", "pulseaudio", "battery", "clock", "tray", "custom/power"],


  // Modules Definition
  "custom/launcher" : {
    "tooltip": true,
    "tooltip-format" : "Start Here :)",
    "format" : "󰣇 ",
    "on-click": "rofi -show drun",
    "on-click-right": "killall rofi"
  },

  "custom/power":{
    "tooltip": true,
    "tooltip-format" : "⏻ Power Options",
    "format": "<span color='#f7768e'>⏻</span>",
    "menu": "on-click",
    "menu-file": "~/.config/waybar/power_menu.xml",
    "menu-actions": {
      "shutdown": "poweroff",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate",
      "lock": "gtklock"
    }
  },

  //workspaces

  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "all-outputs": false,
    "active-only": false,
    "format": "{name}",
    "format-icons": {
      "active": "<span font='12'>󰮯</span>",
      "empty": "<span font='8'></span>",
      "default": ""
    }
  },


  "hyprland/window" : {
    "format" : " {}",
    "separate-outputs": true,
    "max-length": 100
  },

  //items

  "mpris": {
    "player" : "audacious",
    "dynamic-order": ["title", "artist"],
    "format": "{status_icon} <i>{dynamic}</i>",
    "status-icons":{
      "default": "▶" ,
      "paused": "⏸"
    },
  },

  "cpu": {
    "interval": 15,
    "format": "<span color='#19fc78'> </span> {} %",
    "max-length": 10
  },

  "memory": {
    "tooltip" : true,
    "tooltip-format" : "  {used} GB of {total} GB" ,
    "interval": 30,
    "format": "<span color='#7dcfff'> </span> {}% ",
    "format-alt": "<span color='#7dcfff'> </span> {}% {used} GB",
    "max-length": 100
  },

  "disk": {
    "tooltip" : true,
    "tooltip-format" : " {path}  {percentage_used}% used.  {used} of {total} " ,
    "format": "<span color='#d08fff'> </span> {percentage_used}%",
    "format-alt": "<span color='#d08fff'> </span> {used} ",
    "interval": 30,
  },

  "custom/nvidia": {
    "tooltip": true,
    "tooltip-format" : "󰍹 : ",
    "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,nounits,noheader | sed 's/\\([0-9]\\+\\), \\([0-9]\\+\\)/\\1% 🌡️\\2°C/g'",
    "format": "󰍹 {} ",
    "interval": 2
  },

  "cava": {
    //  "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
    "framerate": 60,
    "autosens": 0,
    "sensitivity": 20,
    "bars": 16,
    "lower_cutoff_freq": 40,
    "higher_cutoff_freq": 16000,
    "method": "pulse",
    "source": "auto",
    "stereo": false,
    "reverse": false,
    "hide_on_silence": true,
    "sleep_timer": 20,
    "bar_delimiter": 0,
    "monstercat": false,
    "waves": false,
    "noise_reduction": 0.60,
    "input_delay": 1,
    "format-icons" : ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
    "actions": {
      "on-click-right": "mode"
    }
  },

  "pulseaudio": {
    "tooltip": true,
    "tooltip-format" : "  Master Volume: {desc} ({volume}%)",
    "scroll-step": 5,
    "interval": 1,
    "format": "{icon} {volume}%",
    "format-muted": "<span color='#FF0000'> </span>",
    "on-click":"wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right":"pavucontrol",
    "format-icons": { "default": [
      "<span color='#ff9100'> </span>",
      "<span color='#7aa2f7'> </span>",
      "<span color='#7aa2f7'> </span>",
      "<span color='#7aa2f7'> </span>"
    ]
    }
  },

  "network": {
    "tooltip": true,
    "format-wifi": "<span color='#9ece6a'> </span> ({signalStrength}%)",
    "format-ethernet": "<span color='#7aa2f7'>󰈁</span> {bandwidthDownBytes} ",
    "format-disconnected": "<span color='#FF0000'>󰌙 </span>",
    "interval": 2,
    "tooltip-format-wifi": "󰢩 Interface: {ifname} \n—————————————————————————\n  {essid} \n󰥛 Signal: {signalStrength} % \n Frequency: {frequency}GHz \n—————————————————————————\n󰶡 {bandwidthDownBytes} - 󰶣 {bandwidthUpBytes}\n—————————————————————————\nIP: {ipaddr} \nSubmask: {netmask} \nGateway: {gwaddr}",
    "tooltip-format-ethernet": "󰢩 Interface: {ifname} \n󰈁 LAN \n IP: {ipaddr} \n Submask: {netmask} \n Gateway: {gwaddr}",
    "tooltip-format-disconnected": "󰅛 Disconnected.",
    "on-click": "nm-connection-editor"

  },

  "backlight": {
    "device": "intel_backlight",
    "tooltip": true,
    "tooltip-format" : " Brightness: {0} %",
    "format": "{1} {0}%",
    "interval":1,
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",

    "format-icons": [
      "<span color='#f7b500'>󰃝 </span>",
      "<span color='#f7b500'>󰃟 </span>",
      "<span color='#57ffff'>󰃠 </span>"
    ]
  },

  "clock": {
    "tooltip": true,
    "interval": 60,
    "format": "  {:%I:%M %p}",
    "format-alt": "󰸗 {:%A %d %B %Y   %I:%M %p} ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode"          : "year",
      "mode-mon-col"  : 3,
      // "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "format": {
        "months":     "<span color='#45e9ff'><b>{}</b></span>",
        "days":       "<span color='#f1f1f1'><b>{}</b></span>",
        // "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays":   "<span color='#66a8ff'><b>{}</b></span>",
        "today":      "<span color='#66a8ff'><b><u>{}</u></b></span>"
      }
    },
    "actions":  {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },


}


}

//tray

"traymenu": {
  "icon-size": 15,
  "tooltip": true,
  "show-passive-items": true,
  "spacing": 12
}

}
