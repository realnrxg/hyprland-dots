{
  "layer": "top",
  "width": 1920 ,
  "margin-top": 5,

//modules

  "position": "top",
  "height": 30,
  "margin": 8,
  "spacing": 0,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["cpu", "memory", "disk"],
  "modules-right": ["cava", "traymenu", "network", "backlight", "pulseaudio", "battery", "clock", "tray", "custom/power"],


  // Modules Definition
  "custom/launcher" : {
	"tooltip": true,
	"tooltip-format" : "Start Here :)",
    	"format" : "у°Ј‡ ",
    	"on-click": "rofi -show drun",
    	"on-click-right": "killall rofi"
  },

  "custom/power":{
	"tooltip": true,
	"tooltip-format" : "вЏ» Power Options",
    	"format": "<span color='#f7768e'>вЏ»</span>",	
	"menu": "on-click",
    	"menu-file": "~/.config/waybar/power_menu.xml",
	"menu-actions": {
		"shutdown": "poweroff",
		"reboot": "reboot",
		"suspend": "systemctl suspend",
		"hibernate": "systemctl hibernate",
		"lock": "gtklock"
	}
  },

//workspaces

  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "all-outputs": false,
    "active-only": false,
    "format": "{name}",
    "format-icons": {
        "active": "<span font='12'>у°®Ї</span>",
        "empty": "<span font='8'></span>",
        "default": ""
    }
},


   "hyprland/window" : {
        "format" : "оћ• {}",
	"separate-outputs": true,
	"max-length": 100
   },

//items

   "mpris": {
        "player" : "audacious",
        "dynamic-order": ["title", "artist"],
        "format": "{status_icon} <i>{dynamic}</i>",
        "status-icons":{
                "default": "в–¶" ,
                "paused": "вЏё" 
        },
   },

  "cpu": {
        "interval": 15,
        "format": "<span color='#19fc78'>п‹› </span> {} %",
        "max-length": 10
   },

  "memory": {
	"tooltip" : true,
	"tooltip-format" : "ої…  {used} GB of {total} GB" ,
        "interval": 30,
        "format": "<span color='#7dcfff'>ої… </span> {}% ",
	"format-alt": "<span color='#7dcfff'>ої… </span> {}% {used} GB",
        "max-length": 100
   },

  "disk": {
	"tooltip" : true,
	"tooltip-format" : " {path} п€Ђ {percentage_used}% used. о«Ћ {used} of {total} " ,
        "format": "<span color='#d08fff'>п€Ђ </span> {percentage_used}%",
	"format-alt": "<span color='#d08fff'>п€Ђ </span> {used} ",
        "interval": 30,
   },

  "custom/nvidia": {
	"tooltip": true,
	"tooltip-format" : "у°Ќ№ : ",
    	"exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,nounits,noheader | sed 's/\\([0-9]\\+\\), \\([0-9]\\+\\)/\\1% рџЊЎпёЏ\\2В°C/g'",
    	"format": "у°Ќ№ {} ",
    	"interval": 2
  },

 "cava": {
	//  "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
		"framerate": 60,
		"autosens": 0,
		"sensitivity": 20,
		"bars": 16,
		"lower_cutoff_freq": 40,
		"higher_cutoff_freq": 16000,
		"method": "pulse",
		"source": "auto",
		"stereo": false,
		"reverse": false,
        	"hide_on_silence": true,
        	"sleep_timer": 20,
		"bar_delimiter": 0,
		"monstercat": false,
		"waves": false,
		"noise_reduction": 0.60,
		"input_delay": 1,
		"format-icons" : ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€" ],
		"actions": {
		           "on-click-right": "mode"
		           }
	    },

  "pulsewire": {
		"tooltip": true,
		"tooltip-format" : "пЂЁ  Master Volume: {desc} ({volume}%)",
		"scroll-step": 5,
       		"interval": 1,
		"format": "{icon} {volume}%",
		"format-muted": "<span color='#FF0000'>о»Ё </span>",
		"on-click":"wpctl set-mute @DEFAULT_SINK@ toggle",
		"format-icons": { "default": [
		   "<span color='#ff9100'>пЂ¦ </span>",
		   "<span color='#7aa2f7'>пЂ¦ </span>", 
		   "<span color='#7aa2f7'>пЂ§ </span>", 
		   "<span color='#7aa2f7'>пЂЁ </span>"
           	]
		}
	},

   "network": {
		"tooltip": true,
		"format-wifi": "<span color='#9ece6a'>п‡« </span> ({signalStrength}%)",
		"format-ethernet": "<span color='#7aa2f7'>у°€Ѓ</span> {bandwidthDownBytes} ",
		"format-disconnected": "<span color='#FF0000'>у°Њ™ </span>",
        	"interval": 2,
		"tooltip-format-wifi": "у°ў© Interface: {ifname} \nвЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”\nп‡«  {essid} \nу°Ґ› Signal: {signalStrength} % \n Frequency: {frequency}GHz \nвЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”\nу°¶Ў {bandwidthDownBytes} - у°¶Ј {bandwidthUpBytes}\nвЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”вЂ”\nIP: {ipaddr} \nSubmask: {netmask} \nGateway: {gwaddr}",
		"tooltip-format-ethernet": "у°ў© Interface: {ifname} \nу°€Ѓ LAN \n IP: {ipaddr} \n Submask: {netmask} \n Gateway: {gwaddr}",
		"tooltip-format-disconnected": "у°…› Disconnected.",
		"on-click": "nm-connection-editor"
		
   },

   "backlight": {
		"device": "intel_backlight",
		"tooltip": true,
		"tooltip-format" : "пѓ« Brightness: {0} %",
		"format": "{1} {0}%",
		"interval":1,
        	"on-scroll-up": "brightnessctl set +5%",
		"on-scroll-down": "brightnessctl set 5%-",

		"format-icons": [
			"<span color='#f7b500'>у°ѓќ </span>",
			"<span color='#f7b500'>у°ѓџ </span>",
			"<span color='#57ffff'>у°ѓ  </span>"
		]
    },

   "clock": {
        "tooltip": true,
        "interval": 60,
        "format": "пђє  {:%I:%M %p}",
        "format-alt": "у°ё— {:%A %d %B %Y пђє  %I:%M %p} ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    // "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#45e9ff'><b>{}</b></span>",
                              "days":       "<span color='#f1f1f1'><b>{}</b></span>",
